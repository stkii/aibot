# ================================================================================
# Environment Configuration File Sample
# ================================================================================
#
# SECURITY WARNING:
# DO NOT EXPOSE THIS FILE PUBLICLY AFTER FILLING IN VALUES!
#
# Copy this file to `.env` and replace placeholder values with real credentials.
# Every key below is actually read by the source (verified against the code).
# Per-agent model selection is NOT an env var — configure it in
# `resources/agents.yml` (see `resources/agents-sample.yml`).
#
# ================================================================================

# --------------------------------------------------------------------------------
# DISCORD  (required)
# --------------------------------------------------------------------------------
# Bot token from the Discord Developer Portal.
# The bot exits immediately if this is unset. (src/aibot/__main__.py)
DISCORD_TOKEN=your-discord-bot-token

# Comma-separated guild IDs the bot is allowed to run in (allowlist, fail-closed).
# IMPORTANT: if this is empty/unset, EVERY slash command is rejected.
# (src/aibot/discord/guild_guard.py)
ALLOWED_GUILD_IDS=123456789012345678,234567890123456789

# Comma-separated admin user IDs (bot-wide), required for /set-limit and the
# usage-limit bypass. Read via os.environ[...] with no default, so these commands
# raise if it is missing.
# (discord/decorators/access.py, discord/decorators/usage.py, discord/commands/limit.py)
ADMIN_USER_IDS=123456789012345678,234567890123456789

# --------------------------------------------------------------------------------
# OPENAI  (required for the /ai command)
# --------------------------------------------------------------------------------
# Read automatically by the OpenAI Agents SDK; without it, /ai fails.
OPENAI_API_KEY=sk-your-openai-api-key

# --------------------------------------------------------------------------------
# LIMITS  (optional — defaults shown)
# --------------------------------------------------------------------------------
# Default per-user daily token cap. Falls back to 100 when unset/invalid.
# (src/aibot/services/usage.py)
MAX_DAILY_USAGE=100

# Per-message character limit; longer replies are split into chunks. Capped at
# Discord's hard limit of 2000, which is also the default when unset/invalid.
# (src/aibot/discord/commands/ai.py)
MAX_CHARS_PER_MESSAGE=2000
